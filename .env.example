# ========================================================
# Configuracoes de Ambiente - Map-OS v5
# Copie este arquivo para .env e ajuste os valores
# ========================================================

# Ambiente (development, testing, production)
APP_ENV=development
APP_DEBUG=true

# CSRF Protection
APP_CSRF_PROTECTION=true
APP_CSRF_TOKEN_NAME=MAPOS_TOKEN
APP_CSRF_COOKIE_NAME=MAPOS_COOKIE
APP_CSRF_EXPIRE=7200

# Banco de Dados
DB_HOSTNAME=localhost
DB_USERNAME=root
DB_PASSWORD=
DB_DATABASE=maposv5
DB_DRIVER=mysqli

# E-mail (SMTP)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=seu-email@gmail.com
MAIL_PASS=sua-senha-app
MAIL_CRYPTO=tls

# URL Base (sem barra no final)
BASE_URL=https://seu-dominio.com

# Chave de API (gerar uma string aleatoria forte)
API_KEY=sua-chave-api-aqui

# MercadoPago
MP_PUBLIC_KEY=SEU_PUBLIC_KEY
MP_ACCESS_TOKEN=SEU_ACCESS_TOKEN

# EfiPay / Gerencianet
EFI_CLIENT_ID=SEU_CLIENT_ID
EFI_CLIENT_SECRET=SEU_CLIENT_SECRET

# Asaas
ASAAS_API_KEY=SEU_API_KEY

# Redis / Cache (opcional)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# Google Maps / Geolocalizacao (opcional)
GOOGLE_MAPS_API_KEY=SUA_CHAVE_GOOGLE_MAPS
