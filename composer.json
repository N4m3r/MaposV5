{
    "require": {
        "php": "^8.3",
        "ext-curl": "*",
        "ext-gd": "*",
        "mercadopago/dx-php": "^3.0",
        "efipay/sdk-php-apis-efi": "^1.12",
        "codeigniter/framework": "^3.1.13",
        "mpdf/mpdf": "^8.2.5",
        "filp/whoops": "^2.17.0",
        "mk-j/php_xlsxwriter": "^0.38.0",
        "mpdf/qrcode": "^1.2.1",
        "phpoffice/phpword": "^0.18.3",
        "phpoffice/phpspreadsheet": "^2.0",
        "piggly/php-pix": "^3.0",
        "vlucas/phpdotenv": "^5.6.1",
        "codephix/asaas-sdk": "^2.0",
        "firebase/php-jwt": "^7.0",
        "guzzlehttp/guzzle": "^7.9",
        "predis/predis": "^2.3",
        "symfony/cache": "^7.0",
        "monolog/monolog": "^3.5",
        "dragonmantank/cron-expression": "^3.4"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.68.1",
        "symfony/var-dumper": "^7.0",
        "fakerphp/faker": "^1.24.1",
        "phpunit/phpunit": "^10.5",
        "phpstan/phpstan": "^1.10",
        "squizlabs/php_codesniffer": "^3.9"
    },
    "scripts": {
        "format": [
            "application/vendor/bin/php-cs-fixer fix"
        ]
    },
    "config": {
        "vendor-dir": "application/vendor"
    },
    "autoload": {
        "psr-4": {
            "Libraries\\": "application/libraries",
            "Libraries\\Email\\": "application/libraries/Email",
            "Libraries\\Scheduler\\": "application/libraries/Scheduler",
            "Libraries\\Cache\\": "application/Cache",
            "Libraries\\Validation\\": "application/Validation",
            "Libraries\\Security\\": "application/Security",
            "Libraries\\Notifications\\": "application/libraries/Notifications",
            "Libraries\\Webhooks\\": "application/libraries/Webhooks",
            "Interfaces\\": "application/Interfaces",
            "Repositories\\": "application/Repositories"
        }
    },
    "repositories": [
        {
            "type": "vcs",
            "url": "https://github.com/codephix/asaas-sdk"
        }
    ],
    "type": "project"
}
