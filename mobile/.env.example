# Configuração MAPOS Mobile
# Copie este arquivo para .env e ajuste os valores

# ============================================
# API Configuration
# ============================================
API_BASE_URL=http://localhost/MaposV5/index.php
API_VERSION=v1

# ============================================
# Autenticação
# ============================================
JWT_SECRET=seu_jwt_secret_aqui
JWT_EXPIRATION=86400

# ============================================
# Debug
# ============================================
DEBUG=true
LOG_LEVEL=debug
LOG_TO_FILE=true

# ============================================
# Local Storage
# ============================================
STORAGE_PREFIX=mapos_mobile_

# ============================================
# Sync Configuration
# ============================================
SYNC_INTERVAL=30000
SYNC_RETRY_ATTEMPTS=3
OFFLINE_MODE=true

# ============================================
# Push Notifications (Firebase)
# ============================================
FIREBASE_API_KEY=seu_firebase_key
FIREBASE_PROJECT_ID=seu_project_id

# ============================================
# Geolocation
# ============================================
GEOLOCATION_ACCURACY=high
GEOLOCATION_TIMEOUT=10000

# ============================================
# Camera
# ============================================
CAMERA_QUALITY=high
CAMERA_MAX_WIDTH=1920
CAMERA_MAX_HEIGHT=1080
